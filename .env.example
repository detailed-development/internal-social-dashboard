# Database
DATABASE_URL="postgresql://ncm:ncm_local@db:5432/ncm_social?schema=public"

# Meta (Instagram + Facebook)
META_APP_ID=
META_APP_SECRET=
META_USER_TOKEN=   # Long-lived user token; GET /api/admin/refresh-meta-tokens auto-exchanges + rewrites this
# Each client's page token is stored in the DB, not here

# YouTube
YOUTUBE_API_KEY=

# TikTok (once approved)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# OpenAI Whisper (for transcription)
OPENAI_API_KEY=

# App
PORT=3001
NODE_ENV=development
JWT_SECRET=change-me-in-production

# Auth gate — URL of an endpoint that returns 200 (ok), 401 (not logged in),
# or 403 (logged in but not authorised). The user's Cookie header is forwarded.
# Leave unset to disable the gate in local development.
AUTH_CHECK_URL=http://neoncactusmedia.com/wp-json/ncm/v1/social-dashboard-access

# Token encryption — AES-256-GCM key for OAuth access/refresh tokens at rest.
# Generate a key with: openssl rand -hex 32
# Must be a 64-character hex string. Leave unset to disable encryption (not recommended in production).
ENCRYPTION_KEY=

# ─── Reporting read-model (Phase 2+) ─────────────────────────────────────────
# When 'true', Layer B reads precomputed daily aggregates from the
# ClientPlatformDailyMetric / ClientPostPerformance / ClientWebDailyMetric
# tables instead of re-aggregating raw data. Also causes runFullSync() to
# refresh the rollup window at the end of each sync. Default: false.
# USE_REPORTING_READ_MODEL=false
# REPORTING_REFRESH_WINDOW_DAYS=35

# ─── GitHub Actions nightly sync (optional) ─────────────────────────────────
# For the .github/workflows/nightly-sync.yml workflow, provide the GCP service
# account JSON as a repository secret named GOOGLE_SERVICE_ACCOUNT_JSON instead
# of committing google-service-account.json. Locally, keep the file as-is.

# ─── Bunny Storage (Tools & Plugins ZIP uploads) ────────────────────────────
# Leave empty to disable the Bunny upload path; the UI will fall back to the
# existing local-disk multer flow.
BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_API_KEY=
# Optional region prefix, e.g. "ny", "la", "sg". Empty = default Falkenstein.
BUNNY_STORAGE_REGION=
# Public CDN base URL for the storage zone, no trailing slash.
# Example: https://my-zone.b-cdn.net
BUNNY_CDN_BASE_URL=
# Root key prefix inside the storage zone for plugin ZIPs.
BUNNY_PLUGIN_PREFIX=internal-social-dashboard/tools-plugins
# Max upload size in bytes. Default 340787200 = 325 MB (matches local flow).
PLUGIN_MAX_UPLOAD_BYTES=340787200
# Optional: URL Token Authentication key from the Bunny pull-zone "URL
# Tokens" section. When set, download URLs are signed at read time with
# sha256(key + path + expires) → base64url and appended as ?token=&expires=.
# Leave unset if the pull zone is public.
BUNNY_TOKEN_AUTH_KEY=
BUNNY_TOKEN_TTL_SECONDS=3600
