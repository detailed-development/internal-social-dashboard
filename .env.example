# Database
DATABASE_URL="postgresql://ncm:ncm_local@db:5432/ncm_social?schema=public"

# Meta (Instagram + Facebook)
META_APP_ID=
META_APP_SECRET=
META_USER_TOKEN=   # Long-lived user token; GET /api/admin/refresh-meta-tokens auto-exchanges + rewrites this
# Each client's page token is stored in the DB, not here

# YouTube
YOUTUBE_API_KEY=

# TikTok (once approved)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# OpenAI Whisper (for transcription)
OPENAI_API_KEY=

# App
PORT=3001
NODE_ENV=development
JWT_SECRET=change-me-in-production

# Auth gate — URL of an endpoint that returns 200 (ok), 401 (not logged in),
# or 403 (logged in but not authorised). The user's Cookie header is forwarded.
# Leave unset to disable the gate in local development.
AUTH_CHECK_URL=http://neoncactusmedia.com/wp-json/ncm/v1/social-dashboard-access
