{
  "name": "ncm-social-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Internal social analytics dashboard for Neon Cactus Media",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:client\"",
    "dev:api": "nodemon src/api/server.js",
    "dev:client": "cd client && npm run dev",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "node prisma/seed.js",
    "db:hydrate": "node scripts/hydrate.js",
    "db:studio": "npx prisma studio",
    "worker:sync": "node src/workers/sync-all.js",
    "sync:nightly": "node scripts/nightly-sync.js",
    "reporting:backfill": "node scripts/backfill-reporting-read-model.js",
    "reporting:refresh": "node scripts/refresh-reporting-window.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@google-analytics/admin": "^5.x",
    "@google-analytics/data": "^4.x",
    "@prisma/client": "^5.x",
    "axios": "^1.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "node-cron": "^3.0.3",
    "openai": "^4.x"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.9",
    "concurrently": "^8.x",
    "nodemon": "^3.x",
    "prisma": "^5.x",
    "supertest": "^7.2.2",
    "vitest": "^2.1.9"
  }
}
