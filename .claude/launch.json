{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:api"],
      "port": 3001
    },
    {
      "name": "client",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "cd client && npx vite --port 5180 --strictPort"],
      "port": 5180,
      "autoPort": false
    }
  ]
}
