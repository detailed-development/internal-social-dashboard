generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ClientGroup {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  avatarColor String?  @map("avatar_color")
  sortOrder   Int      @default(0) @map("sort_order")
  clients     Client[]

  @@map("client_groups")
}

model Client {
  id             String          @id @default(uuid())
  name           String
  slug           String          @unique
  avatarColor    String?         @map("avatar_color")
  gaPropertyId   String?         @map("ga_property_id")
  gtmContainerId String?         @map("gtm_container_id")
  websiteUrl     String?         @map("website_url")
  groupId        String?         @map("group_id")
  createdAt      DateTime        @default(now()) @map("created_at")
  group          ClientGroup?    @relation(fields: [groupId], references: [id])
  socialAccounts SocialAccount[]
  webAnalytics   WebAnalytic[]

  // Reporting read-model children
  platformDailyMetrics ClientPlatformDailyMetric[]
  postPerformance      ClientPostPerformance[]
  webDailyMetrics      ClientWebDailyMetric[]
  trafficSourceDaily   ClientTrafficSourceDaily[]
  deviceDaily          ClientDeviceDaily[]
  pageDaily            ClientPageDaily[]
  buzzwordDaily        ClientBuzzwordDaily[]
  reportInputSnapshots ClientReportInputSnapshot[]

  @@map("clients")
}

enum Platform {
  INSTAGRAM
  FACEBOOK
  TIKTOK
  YOUTUBE
  TWITTER
}

enum TokenStatus {
  ACTIVE
  EXPIRED
  REVOKED
  PENDING
}

enum MediaType {
  POST
  REEL
  STORY
  VIDEO
  TWEET
  SHORT
}

model SocialAccount {
  id             String         @id @default(uuid())
  clientId       String         @map("client_id")
  platform       Platform
  platformUserId String         @map("platform_user_id")
  handle         String
  displayName    String?        @map("display_name")
  accessToken    String?        @map("access_token")
  refreshToken   String?        @map("refresh_token")
  tokenStatus    TokenStatus    @default(PENDING) @map("token_status")
  tokenExpiresAt DateTime?      @map("token_expires_at")
  lastSyncedAt   DateTime?      @map("last_synced_at")
  followerCount  Int?           @map("follower_count")
  client         Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  posts          Post[]
  conversations  Conversation[]

  @@unique([platform, platformUserId])
  @@index([clientId])
  @@map("social_accounts")
}

model Post {
  id              String         @id @default(uuid())
  socialAccountId String         @map("social_account_id")
  platformPostId  String         @map("platform_post_id")
  mediaType       MediaType      @map("media_type")
  caption         String?
  permalink       String?
  mediaUrl        String?        @map("media_url")
  thumbnailUrl    String?        @map("thumbnail_url")
  publishedAt     DateTime       @map("published_at")
  fetchedAt       DateTime       @default(now()) @map("fetched_at")
  socialAccount   SocialAccount  @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  metrics         PostMetric[]
  comments        Comment[]
  transcription   Transcription?

  @@unique([socialAccountId, platformPostId])
  @@index([socialAccountId, publishedAt(sort: Desc)])
  @@map("posts")
}

model PostMetric {
  id             String   @id @default(uuid())
  postId         String   @map("post_id")
  impressions    Int      @default(0)
  reach          Int      @default(0)
  likes          Int      @default(0)
  commentsCount  Int      @default(0) @map("comments_count")
  shares         Int      @default(0)
  saves          Int      @default(0)
  videoPlays     Int      @default(0) @map("video_plays")
  engagementRate Float?   @map("engagement_rate")
  recordedAt     DateTime @default(now()) @map("recorded_at")
  post           Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, recordedAt(sort: Desc)])
  @@map("post_metrics")
}

model Comment {
  id                String     @id @default(uuid())
  postId            String     @map("post_id")
  platformCommentId String     @map("platform_comment_id")
  authorName        String?    @map("author_name")
  body              String
  sentimentScore    Float?     @map("sentiment_score")
  postedAt          DateTime   @map("posted_at")
  post              Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  buzzwords         Buzzword[]

  @@unique([postId, platformCommentId])
  @@index([postId, postedAt(sort: Desc)])
  @@map("comments")
}

model Transcription {
  id              String     @id @default(uuid())
  postId          String     @unique @map("post_id")
  transcriptText  String     @map("transcript_text")
  language        String     @default("en")
  confidence      Float?
  durationSeconds Int?       @map("duration_seconds")
  createdAt       DateTime   @default(now()) @map("created_at")
  post            Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  buzzwords       Buzzword[]

  @@map("transcriptions")
}

model WebAnalytic {
  id                 String   @id @default(uuid())
  clientId           String   @map("client_id")
  date               DateTime @map("date") @db.Date
  sessions           Int      @default(0)
  users              Int      @default(0)
  newUsers           Int      @default(0) @map("new_users")
  pageviews          Int      @default(0)
  bounceRate         Float?   @map("bounce_rate")
  avgSessionDuration Float?   @map("avg_session_duration")
  source             String?
  medium             String?
  client             Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, date, source, medium])
  @@index([clientId, date(sort: Desc)])
  @@map("web_analytics")
}

model Conversation {
  id                     String          @id @default(uuid())
  socialAccountId        String          @map("social_account_id")
  platformConversationId String          @map("platform_conversation_id")
  participantName        String?         @map("participant_name")
  participantId          String?         @map("participant_id")
  messageCount           Int             @default(0) @map("message_count")
  lastMessageAt          DateTime?       @map("last_message_at")
  lastSyncedAt           DateTime?       @map("last_synced_at")
  isHidden               Boolean         @default(false) @map("is_hidden")
  socialAccount          SocialAccount   @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  messages               DirectMessage[]

  @@unique([socialAccountId, platformConversationId])
  @@index([socialAccountId, lastMessageAt(sort: Desc)])
  @@map("conversations")
}

model DirectMessage {
  id                String       @id @default(uuid())
  conversationId    String       @map("conversation_id")
  platformMessageId String       @map("platform_message_id")
  fromName          String?      @map("from_name")
  fromId            String?      @map("from_id")
  body              String
  sentAt            DateTime     @map("sent_at")
  isFromPage        Boolean      @default(false) @map("is_from_page")
  conversation      Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, platformMessageId])
  @@index([conversationId, sentAt(sort: Desc)])
  @@map("direct_messages")
}

model Buzzword {
  id              String         @id @default(uuid())
  commentId       String?        @map("comment_id")
  transcriptionId String?        @map("transcription_id")
  word            String
  frequency       Int            @default(1)
  relevanceScore  Float?         @map("relevance_score")
  extractedAt     DateTime       @default(now()) @map("extracted_at")
  comment         Comment?       @relation(fields: [commentId], references: [id], onDelete: Cascade)
  transcription   Transcription? @relation(fields: [transcriptionId], references: [id], onDelete: Cascade)

  @@index([word])
  @@index([commentId])
  @@index([transcriptionId])
  @@map("buzzwords")
}

model AiGeneration {
  id               String    @id @default(uuid())
  feature          String
  cacheKey         String    @unique @map("cache_key")
  clientId         String?   @map("client_id")
  model            String
  promptVersion    String    @map("prompt_version")
  inputHash        String    @map("input_hash")
  dateRangeStart   DateTime? @map("date_range_start")
  dateRangeEnd     DateTime? @map("date_range_end")
  responseFormat   String    @default("markdown") @map("response_format")
  responseBody     String    @map("response_body")
  promptTokens     Int       @default(0) @map("prompt_tokens")
  completionTokens Int       @default(0) @map("completion_tokens")
  totalTokens      Int       @default(0) @map("total_tokens")
  latencyMs        Int?      @map("latency_ms")
  createdAt        DateTime  @default(now()) @map("created_at")
  expiresAt        DateTime? @map("expires_at")

  @@index([feature, clientId])
  @@index([createdAt])
  @@index([expiresAt])
  @@map("ai_generations")
}

// ─── Reporting read-model ──────────────────────────────────────────────────
// Precomputed daily aggregates feeding Layer B (deterministic analytics).
// Populated by src/lib/reporting/*-rollup.js after each successful sync and
// by scripts/backfill-reporting-read-model.js for historical backfills.
// These tables are optional: when USE_REPORTING_READ_MODEL is false, Layer B
// falls back to raw-table aggregation. Cascade deletes from Client keep them
// consistent.

/// One row per (client, socialAccount, date, platform). Sums the latest-metric
/// values across posts published on that date. Feeds platformTotals and
/// dailyEngagement chart series.
model ClientPlatformDailyMetric {
  id              String   @id @default(uuid())
  clientId        String   @map("client_id")
  socialAccountId String?  @map("social_account_id")
  date            DateTime @db.Date
  platform        Platform
  handle          String?
  followerCount   Int      @default(0) @map("follower_count")
  postsCount      Int      @default(0) @map("posts_count")
  likes           Int      @default(0)
  commentsCount   Int      @default(0) @map("comments_count")
  shares          Int      @default(0)
  saves           Int      @default(0)
  reach           Int      @default(0)
  impressions     Int      @default(0)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, date, platform, socialAccountId])
  @@index([clientId, date])
  @@index([clientId, platform, date])
  @@map("client_platform_daily_metrics")
}

/// One row per post, denormalized for reporting. Feeds top-post queries and
/// post-type breakdowns. Engagement is precomputed as likes + comments +
/// shares + saves to match current ranking semantics exactly.
model ClientPostPerformance {
  id              String    @id @default(uuid())
  clientId        String    @map("client_id")
  socialAccountId String?   @map("social_account_id")
  postId          String    @unique @map("post_id")
  date            DateTime  @db.Date
  platform        Platform
  mediaType       MediaType @map("media_type")
  captionPreview  String?   @map("caption_preview") @db.VarChar(160)
  likes           Int       @default(0)
  commentsCount   Int       @default(0) @map("comments_count")
  shares          Int       @default(0)
  saves           Int       @default(0)
  reach           Int       @default(0)
  impressions     Int       @default(0)
  engagement      Int       @default(0)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  client          Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, date])
  @@index([clientId, engagement(sort: Desc), date])
  @@index([clientId, platform, date])
  @@index([clientId, mediaType, date])
  @@map("client_post_performance")
}

/// Daily overview totals from WebAnalytic rows where source='all' AND
/// medium='all'. Feeds dailyTraffic and web KPI tiles.
model ClientWebDailyMetric {
  id                 String   @id @default(uuid())
  clientId           String   @map("client_id")
  date               DateTime @db.Date
  sessions           Int      @default(0)
  users              Int      @default(0)
  newUsers           Int      @default(0) @map("new_users")
  pageviews          Int      @default(0)
  bounceRateAvg      Decimal? @map("bounce_rate_avg") @db.Decimal(6, 2)
  avgSessionDuration Decimal? @map("avg_session_duration") @db.Decimal(10, 2)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  client             Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, date])
  @@index([clientId, date])
  @@map("client_web_daily_metrics")
}

/// Source/medium breakdown by day. Populated from WebAnalytic rows where
/// source NOT IN ('all','_device','_page').
model ClientTrafficSourceDaily {
  id        String   @id @default(uuid())
  clientId  String   @map("client_id")
  date      DateTime @db.Date
  source    String
  medium    String
  sessions  Int      @default(0)
  users     Int      @default(0)
  pageviews Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, date, source, medium])
  @@index([clientId, date])
  @@index([clientId, source, medium, date])
  @@map("client_traffic_source_daily")
}

/// Device breakdown by day. Populated from WebAnalytic rows where
/// source='_device' (medium holds the device name).
model ClientDeviceDaily {
  id        String   @id @default(uuid())
  clientId  String   @map("client_id")
  date      DateTime @db.Date
  device    String
  sessions  Int      @default(0)
  users     Int      @default(0)
  pageviews Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, date, device])
  @@index([clientId, date])
  @@map("client_device_daily")
}

/// Top-page breakdown by day. Populated from WebAnalytic rows where
/// source='_page' (medium holds the page path).
model ClientPageDaily {
  id        String   @id @default(uuid())
  clientId  String   @map("client_id")
  date      DateTime @db.Date
  path      String
  sessions  Int      @default(0)
  users     Int      @default(0)
  pageviews Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, date, path])
  @@index([clientId, date])
  @@map("client_page_daily")
}

/// Date-scoped buzzword aggregates (fixes the current client-only aggregation
/// path in gatherClientAnalytics).
model ClientBuzzwordDaily {
  id        String   @id @default(uuid())
  clientId  String   @map("client_id")
  date      DateTime @db.Date
  word      String
  frequency Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, date, word])
  @@index([clientId, date])
  @@index([clientId, word, date])
  @@map("client_buzzword_daily")
}

/// Optional observability: stores the prompt-input JSON used for a given
/// (client, feature, dateRange, inputVersion) so we can diff regenerated
/// prompts over time.
model ClientReportInputSnapshot {
  id             String   @id @default(uuid())
  clientId       String   @map("client_id")
  feature        String
  dateRangeStart DateTime @map("date_range_start") @db.Date
  dateRangeEnd   DateTime @map("date_range_end") @db.Date
  inputVersion   String   @map("input_version")
  payloadJson    Json     @map("payload_json")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, feature, dateRangeStart, dateRangeEnd, inputVersion])
  @@index([clientId, feature, dateRangeStart, dateRangeEnd])
  @@map("client_report_input_snapshots")
}
